---
import Base from "~/layouts/Base.astro";
---
<Base title="Not found" description="That page doesn't exist.">
  <section class="py-16 text-center">
    <p class="small-caps mb-4">404</p>
    <h1 class="font-serif text-4xl mb-4">Page not found</h1>
    <p class="text-muted mb-6">
      The page you were looking for isn&rsquo;t here. It may have moved, or never existed.
    </p>
    <a href="/" class="!text-accent">← back home</a>
  </section>
</Base>
