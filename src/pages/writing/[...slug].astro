---
import { getCollection, render } from "astro:content";
import Post from "~/layouts/Post.astro";

export async function getStaticPaths() {
  const posts = (await getCollection("blog", ({ data }) => !data.draft))
    .sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime());

  return posts.map((entry, i) => ({
    params: { slug: entry.id },
    props: {
      entry,
      // Reverse-chronological list: i=0 is newest. Prev = older, Next = newer.
      prev: posts[i + 1] ? { slug: posts[i + 1].id, title: posts[i + 1].data.title } : undefined,
      next: posts[i - 1] ? { slug: posts[i - 1].id, title: posts[i - 1].data.title } : undefined,
    },
  }));
}

const { entry, prev, next } = Astro.props;
const { Content } = await render(entry);
---
<Post entry={entry} body={entry.body ?? ""} prev={prev} next={next}>
  <Content />
</Post>
