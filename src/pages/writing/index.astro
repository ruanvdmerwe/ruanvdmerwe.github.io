---
import Base from "~/layouts/Base.astro";
import { getCollection } from "astro:content";
import FormattedDate from "~/components/FormattedDate.astro";

const posts = (await getCollection("blog", ({ data }) => !data.draft))
  .sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime());

const byYear = new Map<number, typeof posts>();
for (const post of posts) {
  const y = post.data.pubDate.getFullYear();
  if (!byYear.has(y)) byYear.set(y, [] as typeof posts);
  byYear.get(y)!.push(post);
}
const years = [...byYear.keys()].sort((a, b) => b - a);
---
<Base
  title="Writing"
  description="Essays and notes on representation learning, continual learning, speech systems, and building research-driven AI products."
>
  <header class="mb-10">
    <h1 class="font-serif text-[2.2rem] sm:text-[2.6rem] tracking-tight mb-3">Writing</h1>
    <p class="text-muted leading-relaxed max-w-reading">
      Essays and notes on representation geometry, continual and meta-learning,
      multilingual speech, and what it takes to ship research into production.
    </p>
  </header>

  {posts.length === 0 ? (
    <p class="text-muted">No posts yet. Check back soon.</p>
  ) : (
    years.map((year) => (
      <section class="mb-10">
        <h2 class="font-serif text-lg text-muted mb-3 tracking-tight">{year}</h2>
        <ul class="divide-y divide-rule border-y border-rule">
          {byYear.get(year)!.map((post) => (
            <li>
              <a
                href={`/writing/${post.id}`}
                class="!no-underline group flex items-baseline justify-between gap-4 py-4"
              >
                <span class="font-serif text-[1.05rem] leading-snug group-hover:text-accent">
                  {post.data.title}
                </span>
                <span class="text-xs text-muted shrink-0 whitespace-nowrap">
                  <FormattedDate date={post.data.pubDate} format="short" />
                </span>
              </a>
            </li>
          ))}
        </ul>
      </section>
    ))
  )}
</Base>
