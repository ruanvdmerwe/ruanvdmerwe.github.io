---
import Base from "~/layouts/Base.astro";
import { getCollection } from "astro:content";
import TalkEntry from "~/components/TalkEntry.astro";

const talks = (await getCollection("talks")).sort(
  (a, b) => b.data.date.getTime() - a.data.date.getTime(),
);
---
<Base
  title="Talks & Media"
  description="Conference talks, workshops, and media appearances on ML research and African AI."
>
  <header class="mb-10">
    <h1 class="font-serif text-[2.2rem] sm:text-[2.6rem] tracking-tight mb-3">Talks &amp; media</h1>
    <p class="text-muted leading-relaxed max-w-reading">
      Conference talks, workshops, and media appearances &mdash; mostly around speech,
      meta-learning, and AI in African contexts.
    </p>
  </header>

  <div>
    {talks.map((entry) => <TalkEntry entry={entry} />)}
  </div>
</Base>
