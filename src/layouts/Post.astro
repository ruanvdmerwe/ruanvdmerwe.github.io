---
import Base from "./Base.astro";
import FormattedDate from "~/components/FormattedDate.astro";
import type { CollectionEntry } from "astro:content";
import readingTime from "reading-time";

type Props = {
  entry: CollectionEntry<"blog">;
  body: string;
  prev?: { slug: string; title: string };
  next?: { slug: string; title: string };
};

const { entry, body, prev, next } = Astro.props;
const { title, description, pubDate, updatedDate, tags, math } = entry.data;
const minutes = Math.max(1, Math.round(readingTime(body).minutes));
---
<Base title={title} description={description} math={math} ogType="article" pubDate={pubDate}>
  <article>
    <header class="mb-10">
      <div class="text-xs text-muted mb-3 flex flex-wrap items-center gap-x-3">
        <FormattedDate date={pubDate} />
        <span>·</span>
        <span>{minutes} min read</span>
        {updatedDate && (
          <>
            <span>·</span>
            <span>updated <FormattedDate date={updatedDate} format="short" /></span>
          </>
        )}
      </div>
      <h1 class="font-serif text-[2.1rem] sm:text-[2.5rem] leading-[1.1] mb-3 tracking-tight">
        {title}
      </h1>
      <p class="text-muted text-lg leading-relaxed">{description}</p>
      {tags.length > 0 && (
        <div class="mt-3 text-xs small-caps">
          {tags.join(" · ")}
        </div>
      )}
    </header>

    <div class="prose-rvdm max-w-reading">
      <slot />
    </div>

    {(prev || next) && (
      <nav class="mt-16 pt-6 border-t border-rule grid grid-cols-2 gap-6 text-sm">
        <div>
          {prev && (
            <a href={`/writing/${prev.slug}`} class="!no-underline group">
              <span class="block small-caps mb-1">← previous</span>
              <span class="font-serif text-base group-hover:text-accent">{prev.title}</span>
            </a>
          )}
        </div>
        <div class="text-right">
          {next && (
            <a href={`/writing/${next.slug}`} class="!no-underline group">
              <span class="block small-caps mb-1">next →</span>
              <span class="font-serif text-base group-hover:text-accent">{next.title}</span>
            </a>
          )}
        </div>
      </nav>
    )}
  </article>
</Base>
