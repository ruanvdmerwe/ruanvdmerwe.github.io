---
import { NAV, SITE } from "~/consts";
import ThemeToggle from "./ThemeToggle.astro";

const path = Astro.url.pathname.replace(/\/$/, "") || "/";
const isActive = (href: string) => {
  if (href === "/") return path === "/";
  return path === href || path.startsWith(href + "/");
};
---
<header class="border-b border-rule">
  <div class="max-w-3xl mx-auto px-5 sm:px-8 py-5 flex items-center justify-between gap-4 sm:gap-6">
    <a
      href="/"
      class="font-serif font-semibold tracking-tight !no-underline hover:!text-accent whitespace-nowrap text-sm sm:text-[1.05rem]"
    >
      <span class="hidden xs:inline">{SITE.title}</span>
      <span class="xs:hidden">Ruan vdM</span>
    </a>
    <nav class="flex items-center gap-x-3 sm:gap-x-5 text-sm">
      {
        NAV.filter((item) => item.href !== "/").map((item) => (
          <a
            href={item.href}
            class:list={[
              "!no-underline transition-colors",
              isActive(item.href) ? "text-accent" : "text-muted hover:text-ink",
            ]}
          >
            {item.label}
          </a>
        ))
      }
      <ThemeToggle />
    </nav>
  </div>
</header>
