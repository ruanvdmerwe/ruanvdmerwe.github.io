---
import FormattedDate from "./FormattedDate.astro";
type Props = {
  href: string;
  title: string;
  description: string;
  pubDate: Date;
  tags?: string[];
};
const { href, title, description, pubDate, tags = [] } = Astro.props;
---
<article class="py-6 border-b border-rule last:border-b-0">
  <a href={href} class="block group !no-underline">
    <div class="text-xs text-muted mb-1">
      <FormattedDate date={pubDate} format="long" />
      {tags.length > 0 && (
        <span> · {tags.join(" · ")}</span>
      )}
    </div>
    <h3 class="font-serif text-xl mb-1 group-hover:text-accent transition-colors">
      {title}
    </h3>
    <p class="text-muted text-[0.95rem] leading-relaxed">{description}</p>
  </a>
</article>
