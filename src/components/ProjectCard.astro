---
import type { CollectionEntry } from "astro:content";
import { render } from "astro:content";

type Props = { entry: CollectionEntry<"projects">; compact?: boolean };
const { entry, compact = false } = Astro.props;
const { Content } = await render(entry);
const { title, summary, period, role, links, tags } = entry.data;
---
<article class="py-6 border-b border-rule last:border-b-0">
  <div class="flex flex-col sm:flex-row sm:items-baseline sm:justify-between gap-1 mb-1">
    <h3 class="font-serif text-xl leading-snug">{title}</h3>
    {period && <span class="text-xs small-caps shrink-0">{period}</span>}
  </div>
  {role && <p class="text-sm text-muted italic mb-2">{role}</p>}
  <p class="text-[0.97rem] text-ink/90 leading-relaxed">{summary}</p>

  {!compact && (
    <div class="prose-rvdm text-[0.96rem] mt-2">
      <Content />
    </div>
  )}

  <div class="mt-3 flex flex-wrap items-center gap-x-3 gap-y-2 text-sm">
    {links.site && <a href={links.site} class="!text-accent" target="_blank" rel="noopener">Site ↗</a>}
    {links.code && <a href={links.code} class="!text-accent" target="_blank" rel="noopener">Code ↗</a>}
    {links.paper && <a href={links.paper} class="!text-accent" target="_blank" rel="noopener">Paper ↗</a>}
    {links.demo && <a href={links.demo} class="!text-accent" target="_blank" rel="noopener">Demo ↗</a>}
    {tags.length > 0 && (
      <span class="text-xs text-muted ml-auto">{tags.join(" · ")}</span>
    )}
  </div>
</article>
